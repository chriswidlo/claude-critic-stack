{
  "permissions": {
    "allow": [
      "Read(//Users/krzys/Development/Projects/claude-critic-stack/**)",
      "Glob(//Users/krzys/Development/Projects/claude-critic-stack/**)",
      "Grep(//Users/krzys/Development/Projects/claude-critic-stack/**)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(./bin/safe-rm.sh:*)",
      "Bash(bin/safe-rm.sh:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(git push:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop.sh" }
        ]
      }
    ]
  }
}
