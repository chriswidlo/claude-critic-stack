# Ingested canon text bodies: regenerated by bin/ingest-canon.mjs or
# populated from local plaintext via bin/ingest-owned-book.mjs.
# The rest of canon/corpus/ (stubs, citation.yaml, README.md) IS tracked
# so the corpus inventory is visible in git.
canon/corpus/*/source.txt

# Local Claude Code settings (per-developer overrides, e.g. domain allowlist,
# Bash permissions). The shared settings.json IS tracked.
.claude/settings.local.json

# Per-session reasoning artifacts produced by the 12-step workflow.
# Tracked as a longitudinal human-facing record (drift detection, growth
# vs regression analysis over time). The AI is not instructed to read
# prior sessions — its perspective remains ephemeral scratchpad.
# Do NOT prune for noise: low-value sessions are diagnostic data.
# Periodic sweeps should be for PRIVACY REDACTION only (scrub pasted-in
# proprietary names from other repos), not deletion.
# See .claude/session-artifacts/README.md for the lifecycle.

.DS_Store
